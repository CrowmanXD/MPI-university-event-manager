# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://admin:secretpassword@localhost:5432/event_manager

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ── App ─────────────────────────────────────────────────────────────────────
# Base URL used in verification email links
APP_BASE_URL=http://localhost:8080

# Only emails ending with this domain will be accepted at registration
UNIVERSITY_DOMAIN=student.university.edu

# ── SMTP (email sending) ─────────────────────────────────────────────────────
# Example values work with Mailtrap (https://mailtrap.io) for local testing
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM="University Events" <no-reply@university.edu>
